{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Josepavese/nido",
  "title": "Nido — Fast, Simple VM Sandboxes for AI Agents (Temporary & Persistent)",
  "description": "Manage temporary or persistent Linux VMs (QEMU/KVM). Designed for AI agents and automation.",
  "version": "0.0.0-dev",
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/Josepavese/nido/releases/download/v0.0.0-dev/nido.mcpb",
      "version": "0.0.0-dev",
      "transport": {
        "type": "stdio",
        "command": "nido",
        "args": [
          "mcp"
        ],
        "platform": {
          "windows": {
            "command": "nido.exe",
            "args": [
              "mcp"
            ]
          }
        }
      },
      "fileSha256": "SHA256_PLACEHOLDER"
    }
  ],
  "tools": [
    {
      "name": "nido_vm"
    },
    {
      "name": "nido_template"
    },
    {
      "name": "nido_image"
    },
    {
      "name": "nido_system"
    }
  ]
}
